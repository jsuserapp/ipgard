server:
  port: 9300
  # 反向代理子路径，例如 sul2100.cn/ipgard 则设为 /ipgard
  base_path: ""

auth:
  # 首次启动时写入数据库；之后可在设置页修改
  password: "admin"

database:
  path: "./data/ipgard.db"

scanner:
  interval_seconds: 10

firewall:
  enabled: true
  chain: IPGARD
  # 网段封禁使用的 ipset 名称
  cidr_ipset: IPGARD_NET
  # 与手动 iptables 一致；legacy 环境可设为 /sbin/iptables-legacy
  iptables_path: iptables
  ipset_path: ipset

geoip:
  enabled: true
  # 使用 IPv4 库即可；日志无 IPv6 时可忽略 ip2region_v6.xdb
  db_path: "./data/ip2region_v4.xdb"
